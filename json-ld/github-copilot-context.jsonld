{
  "@context": {
    "@vocab": "https://schema.org/",
    "github": "https://docs.github.com/en/rest/copilot/",
    "copilot": "https://docs.github.com/en/rest/copilot#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "CopilotSeatDetail": {
      "@id": "copilot:CopilotSeatDetail",
      "@context": {
        "created_at": {
          "@id": "schema:dateCreated",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "schema:dateModified",
          "@type": "xsd:dateTime"
        },
        "pending_cancellation_date": {
          "@id": "copilot:pendingCancellationDate",
          "@type": "xsd:date"
        },
        "last_activity_at": {
          "@id": "copilot:lastActivityAt",
          "@type": "xsd:dateTime"
        },
        "last_activity_editor": {
          "@id": "copilot:lastActivityEditor",
          "@type": "xsd:string"
        },
        "last_authenticated_at": {
          "@id": "copilot:lastAuthenticatedAt",
          "@type": "xsd:dateTime"
        },
        "plan_type": {
          "@id": "copilot:planType",
          "@type": "xsd:string"
        },
        "assignee": {
          "@id": "copilot:assignee",
          "@type": "@id"
        },
        "assigning_team": {
          "@id": "copilot:assigningTeam",
          "@type": "@id"
        }
      }
    },

    "SimpleUser": {
      "@id": "schema:Person",
      "@context": {
        "login": {
          "@id": "schema:alternateName",
          "@type": "xsd:string"
        },
        "id": {
          "@id": "schema:identifier",
          "@type": "xsd:integer"
        },
        "node_id": {
          "@id": "copilot:nodeId",
          "@type": "xsd:string"
        },
        "avatar_url": {
          "@id": "schema:image",
          "@type": "@id"
        },
        "url": {
          "@id": "schema:url",
          "@type": "@id"
        },
        "html_url": {
          "@id": "schema:mainEntityOfPage",
          "@type": "@id"
        },
        "type": {
          "@id": "schema:additionalType",
          "@type": "xsd:string"
        },
        "site_admin": {
          "@id": "copilot:isSiteAdmin",
          "@type": "xsd:boolean"
        }
      }
    },

    "Team": {
      "@id": "schema:Organization",
      "@context": {
        "id": {
          "@id": "schema:identifier",
          "@type": "xsd:integer"
        },
        "node_id": {
          "@id": "copilot:nodeId",
          "@type": "xsd:string"
        },
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "slug": {
          "@id": "schema:alternateName",
          "@type": "xsd:string"
        },
        "description": {
          "@id": "schema:description",
          "@type": "xsd:string"
        },
        "privacy": {
          "@id": "copilot:privacyLevel",
          "@type": "xsd:string"
        },
        "url": {
          "@id": "schema:url",
          "@type": "@id"
        },
        "html_url": {
          "@id": "schema:mainEntityOfPage",
          "@type": "@id"
        }
      }
    },

    "SeatBreakdown": {
      "@id": "copilot:SeatBreakdown",
      "@context": {
        "total": {
          "@id": "copilot:totalSeats",
          "@type": "xsd:integer"
        },
        "added_this_cycle": {
          "@id": "copilot:seatsAddedThisCycle",
          "@type": "xsd:integer"
        },
        "pending_invitation": {
          "@id": "copilot:seatsPendingInvitation",
          "@type": "xsd:integer"
        },
        "pending_cancellation": {
          "@id": "copilot:seatsPendingCancellation",
          "@type": "xsd:integer"
        },
        "active_this_cycle": {
          "@id": "copilot:seatsActiveThisCycle",
          "@type": "xsd:integer"
        },
        "inactive_this_cycle": {
          "@id": "copilot:seatsInactiveThisCycle",
          "@type": "xsd:integer"
        }
      }
    },

    "CopilotBillingInfo": {
      "@id": "copilot:CopilotBillingInfo",
      "@context": {
        "seat_breakdown": {
          "@id": "copilot:seatBreakdown",
          "@type": "copilot:SeatBreakdown"
        },
        "seat_management_setting": {
          "@id": "copilot:seatManagementSetting",
          "@type": "xsd:string"
        },
        "ide_chat": {
          "@id": "copilot:ideChatPolicy",
          "@type": "xsd:string"
        },
        "platform_chat": {
          "@id": "copilot:platformChatPolicy",
          "@type": "xsd:string"
        },
        "cli": {
          "@id": "copilot:cliPolicy",
          "@type": "xsd:string"
        },
        "public_code_suggestions": {
          "@id": "copilot:publicCodeSuggestionsPolicy",
          "@type": "xsd:string"
        },
        "plan_type": {
          "@id": "copilot:planType",
          "@type": "xsd:string"
        }
      }
    },

    "CopilotMetricsDay": {
      "@id": "copilot:CopilotMetricsDay",
      "@context": {
        "date": {
          "@id": "schema:datePublished",
          "@type": "xsd:date"
        },
        "total_active_users": {
          "@id": "copilot:totalActiveUsers",
          "@type": "xsd:integer"
        },
        "total_engaged_users": {
          "@id": "copilot:totalEngagedUsers",
          "@type": "xsd:integer"
        },
        "copilot_ide_code_completions": {
          "@id": "copilot:ideCodeCompletions",
          "@type": "copilot:CopilotIdeCodeCompletions"
        },
        "copilot_ide_chat": {
          "@id": "copilot:ideChat",
          "@type": "copilot:CopilotIdeChat"
        },
        "copilot_dotcom_chat": {
          "@id": "copilot:dotcomChat",
          "@type": "copilot:CopilotDotcomChat"
        },
        "copilot_dotcom_pull_requests": {
          "@id": "copilot:dotcomPullRequests",
          "@type": "copilot:CopilotDotcomPullRequests"
        }
      }
    },

    "CopilotIdeCodeCompletions": {
      "@id": "copilot:CopilotIdeCodeCompletions",
      "@context": {
        "total_engaged_users": {
          "@id": "copilot:totalEngagedUsers",
          "@type": "xsd:integer"
        },
        "languages": {
          "@id": "copilot:languages",
          "@container": "@list"
        },
        "editors": {
          "@id": "copilot:editors",
          "@container": "@list"
        }
      }
    },

    "CodeCompletionsLanguageMetrics": {
      "@id": "copilot:CodeCompletionsLanguageMetrics",
      "@context": {
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "total_engaged_users": {
          "@id": "copilot:totalEngagedUsers",
          "@type": "xsd:integer"
        },
        "total_code_suggestions": {
          "@id": "copilot:totalCodeSuggestions",
          "@type": "xsd:integer"
        },
        "total_code_acceptances": {
          "@id": "copilot:totalCodeAcceptances",
          "@type": "xsd:integer"
        },
        "total_code_lines_suggested": {
          "@id": "copilot:totalCodeLinesSuggested",
          "@type": "xsd:integer"
        },
        "total_code_lines_accepted": {
          "@id": "copilot:totalCodeLinesAccepted",
          "@type": "xsd:integer"
        }
      }
    },

    "CopilotIdeChat": {
      "@id": "copilot:CopilotIdeChat",
      "@context": {
        "total_engaged_users": {
          "@id": "copilot:totalEngagedUsers",
          "@type": "xsd:integer"
        },
        "editors": {
          "@id": "copilot:editors",
          "@container": "@list"
        }
      }
    },

    "IdeChatModel": {
      "@id": "copilot:IdeChatModel",
      "@context": {
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "is_custom_model": {
          "@id": "copilot:isCustomModel",
          "@type": "xsd:boolean"
        },
        "total_chats": {
          "@id": "copilot:totalChats",
          "@type": "xsd:integer"
        },
        "total_chat_insertion_events": {
          "@id": "copilot:totalChatInsertionEvents",
          "@type": "xsd:integer"
        },
        "total_chat_copy_events": {
          "@id": "copilot:totalChatCopyEvents",
          "@type": "xsd:integer"
        }
      }
    },

    "CopilotDotcomChat": {
      "@id": "copilot:CopilotDotcomChat",
      "@context": {
        "total_engaged_users": {
          "@id": "copilot:totalEngagedUsers",
          "@type": "xsd:integer"
        },
        "models": {
          "@id": "copilot:models",
          "@container": "@list"
        }
      }
    },

    "CopilotDotcomPullRequests": {
      "@id": "copilot:CopilotDotcomPullRequests",
      "@context": {
        "total_engaged_users": {
          "@id": "copilot:totalEngagedUsers",
          "@type": "xsd:integer"
        },
        "repositories": {
          "@id": "copilot:repositories",
          "@container": "@list"
        }
      }
    },

    "PullRequestModel": {
      "@id": "copilot:PullRequestModel",
      "@context": {
        "name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "is_custom_model": {
          "@id": "copilot:isCustomModel",
          "@type": "xsd:boolean"
        },
        "total_pr_summaries_created": {
          "@id": "copilot:totalPrSummariesCreated",
          "@type": "xsd:integer"
        },
        "total_engaged_users": {
          "@id": "copilot:totalEngagedUsers",
          "@type": "xsd:integer"
        }
      }
    },

    "UsageReportDaily": {
      "@id": "copilot:UsageReportDaily",
      "@context": {
        "download_links": {
          "@id": "schema:downloadUrl",
          "@container": "@list"
        },
        "report_day": {
          "@id": "copilot:reportDay",
          "@type": "xsd:date"
        }
      }
    },

    "UsageReport28Day": {
      "@id": "copilot:UsageReport28Day",
      "@context": {
        "download_links": {
          "@id": "schema:downloadUrl",
          "@container": "@list"
        },
        "report_start_day": {
          "@id": "copilot:reportStartDay",
          "@type": "xsd:date"
        },
        "report_end_day": {
          "@id": "copilot:reportEndDay",
          "@type": "xsd:date"
        }
      }
    },

    "ContentExclusionRules": {
      "@id": "copilot:ContentExclusionRules",
      "@context": {
        "repository": {
          "@id": "copilot:repository",
          "@type": "xsd:string"
        },
        "paths": {
          "@id": "copilot:excludedPaths",
          "@container": "@list"
        }
      }
    }
  }
}
